\begin{MintedVerbatim}[commandchars=\\\{\}]
\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{task}\PYG{p}{(}\PYG{n}{name}\PYG{p}{,} \PYG{n}{count}\PYG{p}{)}\PYG{p}{:}
